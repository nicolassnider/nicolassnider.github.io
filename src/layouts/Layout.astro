---
import '../styles/global.css';
import { AUTHOR_NAME, AUTHOR_GITHUB, AUTHOR_LINKEDIN } from '../config';
import { ui } from '../data/ui';
import { skills } from '../data/skills';
import type { I18nProps } from '../types';
import AosInit from '../components/AosInit';

type Props = I18nProps;

const { lang } = Astro.props;
const t = ui[lang];
---
<!doctype html>
<html lang={lang} class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
		<link rel="icon" href="/favicon.ico?v=2" />
		<meta name="generator" content={Astro.generator} />
		<title>{AUTHOR_NAME} | {t['hero.title']}</title>
		<meta name="description" content={t['hero.description']} />
		<meta name="author" content={AUTHOR_NAME} />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={`${AUTHOR_NAME} | ${t['hero.title']}`} />
		<meta property="og:description" content={t['hero.description']} />
		<meta property="og:image" content={new URL('/images/og-image.png', Astro.url)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={`${AUTHOR_NAME} | ${t['hero.title']}`} />
		<meta property="twitter:description" content={t['hero.description']} />
		<meta property="twitter:image" content={new URL('/images/og-image.png', Astro.url)} />
		
		<!-- Canonical URL -->
		<link rel="canonical" href={Astro.url} />

		<!-- JSON-LD Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Person",
			"name": AUTHOR_NAME,
			"url": Astro.url,
			"jobTitle": t['hero.title'],
			"image": new URL('/images/og-image.png', Astro.url).toString(),
			"sameAs": [
				AUTHOR_GITHUB,
				AUTHOR_LINKEDIN
			],
			"knowsAbout": skills[lang]
		})} />
	</head>
	<body class="bg-gray-50 dark:bg-gray-950 text-gray-900 dark:text-gray-100 min-h-screen flex flex-col font-sans relative selection:bg-blue-500/30">
		{/* Ambient Background Gradient for Glassmorphism to pop */}
		<div class="fixed inset-0 z-[-1] overflow-hidden pointer-events-none">
			<div class="absolute -top-[40%] -left-[20%] w-[70%] h-[70%] rounded-full bg-blue-500/10 dark:bg-blue-600/10 blur-3xl"></div>
			<div class="absolute top-[60%] -right-[10%] w-[60%] h-[60%] rounded-full bg-purple-500/10 dark:bg-purple-600/10 blur-3xl"></div>
		</div>
		<slot />
		<footer class="bg-gray-50 dark:bg-gray-950 py-8 border-t border-gray-200 dark:border-gray-800 text-center mt-auto">
			<p class="text-sm text-gray-500 dark:text-gray-400">
				&copy; {new Date().getFullYear()} {AUTHOR_NAME}. {lang === 'en' ? 'All rights reserved.' : 'Todos los derechos reservados.'}
			</p>
		</footer>
		
		<AosInit client:load />
	</body>
</html>
