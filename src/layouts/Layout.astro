---
import '../styles/global.css';
import { AUTHOR_NAME } from '../config';
---
<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{AUTHOR_NAME} | .NET Developer & Software Engineer</title>
	</head>
	<body class="bg-gray-50 text-gray-900 dark:bg-gray-950 dark:text-gray-100 antialiased selection:bg-blue-500 selection:text-white flex flex-col min-h-screen">
		<slot />
	</body>
</html>
